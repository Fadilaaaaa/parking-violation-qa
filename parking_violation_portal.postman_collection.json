          "name": "Re-fetch old violation — amount must be unchanged — CRITICAL-05",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('🔴 CRITICAL-05: Past violation amount not changed by new rule', () => {",
                  "  const json = pm.response.json();",
                  "  const originalAmount = pm.collectionVariables.get('RULE_TEST_AMOUNT');",
                  "  pm.expect(String(json.final_amount)).to.eql(String(originalAmount));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{OFFICER_TOKEN}}" }],
            "url": "{{BASE_URL}}/violations/{{RULE_TEST_VID}}"
          }
        }
      ]
