  },
  "variable": [
    { "key": "BASE_URL", "value": "http://localhost:8090" },
    { "key": "OFFICER_TOKEN", "value": "" },
    { "key": "MEMBER1_TOKEN", "value": "" },
    { "key": "MEMBER2_TOKEN", "value": "" },
    { "key": "MEMBER5_TOKEN", "value": "" },
    { "key": "VIOLATION_ID", "value": "" },
    { "key": "INVOICE_ID", "value": "" },
    { "key": "NIGHT_VIOLATION_ID", "value": "" }
  ],
  "item": [
    {
      "name": "1. Authentication",
      "item": [
        {
          "name": "Health Check (public)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Body contains ok', () => pm.expect(pm.response.json().status).to.eql('ok'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/health"
          }
        },
        {
          "name": "Login — Officer 1",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Token returned', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.token).to.be.a('string');",
                  "  pm.collectionVariables.set('OFFICER_TOKEN', json.token);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{BASE_URL}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"officer1@portal.test\", \"password\": \"password\"}"
            }
          }
        },
        {
          "name": "Login — Member 1",
